
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Steam Store</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="styles.css">
</head>
<body style="background-color:#1b2838">
    <div class="container my-5">
        <h2 class="text-white">Biblioteca</h2>
        <div class="row">
            <div class="col-md-3">
                <div class="card bg-dark text-white">
                    <img src="data:image/jpeg;base64," class="card-img-top" alt="Juego 1">
                    <div class="card-body">
                        <h5 class="card-title">Juego 1</h5>
                        <p class="card-text">Última vez jugado: Ayer</p>
                        <a href="#" class="btn btn-success">Jugar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-dark text-white">
                    <img src="data:image/jpeg;base64," class="card-img-top" alt="Juego 2">
                    <div class="card-body">
                        <h5 class="card-title">Juego 2</h5>
                        <p class="card-text">Última vez jugado: Hace 3 días</p>
                        <a href="#" class="btn btn-success">Jugar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-dark text-white">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTiyTMTscV9Ghj_PhGCGw7CVKe3WrGDqhglEA&s" class="card-img-top" alt="Juego 3">
                    <div class="card-body">
                        <h5 class="card-title">Juego 3</h5>
                        <p class="card-text">Última vez jugado: Hace 1 semana</p>
                        <a href="#" class="btn btn-success">Jugar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-3">
        <p>&copy; 2025 GameStorm. Todos los derechos reservados.</p>
    </footer>
</body>
</html>
